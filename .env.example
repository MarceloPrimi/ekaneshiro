# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA suba o arquivo .env para o repositório.
# ============================================================

# --- Banco de Dados ---
# Formato MySQL/TiDB Cloud:
#   mysql+pymysql://<usuario>:<senha>@<host>:<porta>/<banco>?ssl_verify_cert=true&ssl_verify_identity=true
DATABASE_URL=mysql+pymysql://usuario:senha@host:4000/sgk?ssl_verify_cert=true&ssl_verify_identity=true

# --- Segurança JWT ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-um-valor-aleatorio-seguro
ALGORITHM=HS256
# 720 = 12h. Valores baixos deslogam o usuário no meio do uso (cada 401 por
# expiração dispara logout no frontend e gera erros "Not authenticated").
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- CORS ---
# URLs do seu frontend separadas por vírgula (sem barra no final)
ALLOWED_ORIGINS=https://seu-app.vercel.app

# --- Google Service Account ---
# Cole o conteúdo COMPLETO do service_account.json como string JSON (em uma única linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- Google Sheets ---
GOOGLE_SPREADSHEET_ID=id-da-sua-planilha-mestre

# --- Google OAuth (se usar login social) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://seu-backend.onrender.com/auth/google/callback
